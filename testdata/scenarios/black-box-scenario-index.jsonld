{
  "@context": "../manifests/support/accord-context.jsonld",
  "type": "ScenarioIndex",
  "id": "urn:accord:testdata:black-box-scenario-index",
  "dcterms:title": "Black-box scenario index sample",
  "defaultFixtureRepo": "testdata/repos/repo-files",
  "branchPrefix": "r",
  "assetRoot": [
    ".assets"
  ],
  "hasStateLane": [
    {
      "id": "#source-lane",
      "type": "StateLane",
      "laneKey": "source",
      "branchPrefix": "source"
    },
    {
      "id": "#publication-lane",
      "type": "StateLane",
      "laneKey": "publication",
      "branchPrefix": "r"
    }
  ],
  "hasStep": [
    {
      "id": "#bytes-added",
      "type": "ScenarioStep",
      "manifestPath": "testdata/manifests/bb-001-single-case-auto-select-pass.jsonld",
      "caseId": "#auto-select-case",
      "hasLaneBinding": [
        {
          "type": "LaneStateBinding",
          "lane": "#source-lane",
          "fromLaneState": {
            "type": "StateLocator",
            "locatorKind": "gitRefState",
            "ref": "source-r0"
          },
          "toLaneState": {
            "type": "StateLocator",
            "locatorKind": "gitRefState",
            "ref": "source-r1"
          }
        },
        {
          "type": "LaneStateBinding",
          "lane": "#publication-lane",
          "fromLaneState": {
            "type": "StateLocator",
            "locatorKind": "gitRefState",
            "ref": "r0-empty"
          },
          "toLaneState": {
            "type": "StateLocator",
            "locatorKind": "gitRefState",
            "ref": "r1-bytes-a"
          }
        }
      ]
    },
    {
      "id": "#bytes-updated",
      "type": "ScenarioStep",
      "manifestPath": "testdata/manifests/bb-102-updated-bytes-pass.jsonld",
      "caseId": "#updated-bytes-case",
      "hasLaneBinding": [
        {
          "type": "LaneStateBinding",
          "lane": "#source-lane",
          "fromLaneState": {
            "type": "StateLocator",
            "locatorKind": "gitRefState",
            "ref": "source-r1"
          },
          "toLaneState": {
            "type": "StateLocator",
            "locatorKind": "gitRefState",
            "ref": "source-r2"
          }
        },
        {
          "type": "LaneStateBinding",
          "lane": "#publication-lane",
          "fromLaneState": {
            "type": "StateLocator",
            "locatorKind": "gitRefState",
            "ref": "r1-bytes-a"
          },
          "toLaneState": {
            "type": "StateLocator",
            "locatorKind": "gitRefState",
            "ref": "r2-bytes-b"
          }
        }
      ]
    }
  ]
}
