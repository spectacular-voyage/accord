    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "locatorKind": {
      "@type": "@vocab"
    },
    "operationKind": {
      "@type": "@vocab"
    },
    "promptPolicy": {
      "@type": "@vocab"
    },
    "sourceKind": {
      "@type": "@vocab"
    },
    "argv": {
