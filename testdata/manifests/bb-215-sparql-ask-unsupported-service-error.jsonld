      ],
      "hasRdfExpectation": [
        {
          "id": "#graph-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#graph-file",
          "hasAskAssertion": [
            {
              "id": "#ask-unsupported-service",
              "type": "SparqlAskAssertion",
              "query": "ASK { SERVICE <https://example.invalid/sparql> { ?s ?p ?o . } }",
              "expectedBoolean": true
            }
          ]
        }
      ]
