  "id": "urn:accord:testdata:bb-215-sparql-ask-unsupported-service-error",
  "dcterms:title": "bb-215 SPARQL ASK unsupported SERVICE error",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#sparql-ask-unsupported-service-case",
      "fixtureRepo": "testdata/repos/repo-rdf",
      "operationId": "test.sparqlAskUnsupportedService",
      "fromRef": "r0-empty",
      "toRef": "r1-graph-v1",
      "hasFileExpectation": [
        {
          "id": "#graph-file",
          "type": "FileExpectation",
          "path": "graph.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
