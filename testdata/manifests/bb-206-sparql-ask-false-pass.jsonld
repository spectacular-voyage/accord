  "id": "urn:accord:testdata:bb-206-sparql-ask-false-pass",
  "dcterms:title": "bb-206 SPARQL ASK false pass",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#sparql-ask-false-case",
      "fixtureRepo": "testdata/repos/repo-rdf",
      "operationId": "test.sparqlAskFalse",
      "fromRef": "r0-empty",
      "toRef": "r1-graph-v1",
      "hasFileExpectation": [
        {
          "id": "#graph-file",
          "type": "FileExpectation",
          "path": "graph.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#graph-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#graph-file",
          "hasAskAssertion": [
            {
              "id": "#ask-carol-person",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://example.test/carol> a <https://example.test/Person> . }",
              "expectedBoolean": false
            }
          ]
        }
      ]
    }
