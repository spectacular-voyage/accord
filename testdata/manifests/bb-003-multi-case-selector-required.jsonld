    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    }
  },
  "type": "Manifest",
  "id": "urn:accord:testdata:bb-003-multi-case-selector-required",
  "dcterms:title": "bb-003 multi-case selector required",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#selected-case",
      "fixtureRepo": "testdata/repos/repo-files",
      "operationId": "test.selectCase",
      "fromRef": "r0-empty",
      "toRef": "r1-bytes-a",
      "hasFileExpectation": [
        {
          "id": "#selected-artifact",
          "type": "FileExpectation",
          "path": "artifact.bin",
          "changeType": "added",
          "compareMode": "bytes"
        }
      ]
    },
    {
      "type": "TransitionCase",
      "id": "#other-case",
      "fixtureRepo": "testdata/repos/repo-files",
      "operationId": "test.selectCase.other",
      "fromRef": "r3-text-lf",
      "toRef": "r5-text-changed",
      "hasFileExpectation": [
        {
          "id": "#other-note",
          "type": "FileExpectation",
          "path": "note.txt",
          "changeType": "updated",
          "compareMode": "text"
        }
      ]
    }
  ]
}
