{
  "@context": {
    "@vocab": "https://spectacular-voyage.github.io/accord/ns#",
    "dcterms": "http://purl.org/dc/terms/",
    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "locatorKind": {
      "@type": "@vocab"
    },
    "operationKind": {
      "@type": "@vocab"
    },
    "promptPolicy": {
      "@type": "@vocab"
    },
    "sourceKind": {
      "@type": "@vocab"
    },
    "argv": {
      "@container": "@list"
    },
    "ignorePaths": {
      "@container": "@list"
    }
  }
}
