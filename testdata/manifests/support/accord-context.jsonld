{
  "@context": {
    "@vocab": "https://spectacular-voyage.github.io/accord/ontology/",
    "dcterms": "http://purl.org/dc/terms/",
    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "jsonAssertionKind": {
      "@type": "@vocab"
    },
    "locatorKind": {
      "@type": "@vocab"
    },
    "operationKind": {
      "@type": "@vocab"
    },
    "promptPolicy": {
      "@type": "@vocab"
    },
    "sourceKind": {
      "@type": "@vocab"
    },
    "lane": {
      "@type": "@id"
    },
    "targetsFileExpectation": {
      "@type": "@id"
    },
    "argv": {
      "@container": "@list"
    },
    "hasStep": {
      "@container": "@list"
    },
    "ignorePaths": {
      "@container": "@list"
    }
  }
}
