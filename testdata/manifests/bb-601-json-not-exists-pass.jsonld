  "type": "Manifest",
  "id": "urn:accord:testdata:bb-601-json-not-exists-pass",
  "dcterms:title": "bb-601 JSON absence proof pass",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#json-not-exists-pass-case",
      "fixtureRepo": "testdata/repos/repo-files",
      "operationId": "test.jsonNotExistsPass",
      "fromRef": "r0-empty",
      "toRef": "r7-json-clean",
      "hasFileExpectation": [
        {
          "id": "#contract-file",
          "type": "FileExpectation",
          "path": "contract.json",
          "changeType": "added",
          "compareMode": "json"
        }
      ],
      "hasJsonExpectation": [
        {
          "id": "#contract-json",
          "type": "JsonExpectation",
          "targetsFileExpectation": "#contract-file",
          "hasJsonAssertion": [
            {
              "id": "#no-participant-aim-leak",
              "type": "JsonAssertion",
              "jsonPath": "$..participantAim",
              "jsonAssertionKind": "notExists"
            }
          ]
        }
      ]
    }
  ]
}
