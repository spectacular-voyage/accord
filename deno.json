{
  "tasks": {
    "fmt": "deno fmt deno.json src tests testdata",
    "fmt:check": "deno fmt --check deno.json src tests testdata",
    "lint": "deno lint src tests",
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "test": "deno test --allow-read --allow-write --allow-run --allow-env tests",
    "test:black-box": "deno test --allow-read --allow-write --allow-run --allow-env tests/black_box_test.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@1",
    "@std/path": "jsr:@std/path@1",
    "jsonld": "npm:jsonld@8.3.3"
  },
  "exclude": [
    ".test-tmp/**",
    "documentation/notes/**"
  ],
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "documentation/notes/**",
      "**/*.md"
    ]
  }
}
