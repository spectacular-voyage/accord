@base <https://spectacular-voyage.github.io/accord/ontology/> .
@prefix accord: <https://spectacular-voyage.github.io/accord/ontology/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://spectacular-voyage.github.io/accord/ontology> a owl:Ontology ;
  dcterms:title "Accord Ontology" ;
  dcterms:description "A small ontology for machine-readable conformance manifests and reusable acceptance checks." ;
  dcterms:creator <https://djradon.github.io/ns/dave-richardson> ;
  dcterms:hasVersion <https://spectacular-voyage.github.io/accord/ontology/releases/v0.1.0> ;
  dcterms:modified "2026-05-23"^^xsd:date ;
  owl:versionIRI <https://raw.githubusercontent.com/spectacular-voyage/accord/refs/tags/v0.1.0/accord-ontology.ttl> ;
  owl:versionInfo "0.1.0" ;
  vann:preferredNamespacePrefix "accord" ;
  vann:preferredNamespaceUri "https://spectacular-voyage.github.io/accord/ontology/" ;
  rdfs:comment "Accord models manifests as executable acceptance metadata rather than long-form prose specifications." .

<https://spectacular-voyage.github.io/accord/ontology/releases/v0.1.0>
  a owl:Ontology, sflo:HistoricalState ;
  dcterms:isVersionOf <https://spectacular-voyage.github.io/accord/ontology> ;
  dcterms:issued "2026-05-23"^^xsd:date ;
  owl:versionInfo "0.1.0" ;
  schema:contentUrl <https://spectacular-voyage.github.io/accord/ontology/releases/v0.1.0/ttl/accord-ontology.ttl> ;
  sflo:hasManifestation <https://spectacular-voyage.github.io/accord/ontology/releases/v0.1.0/ttl> .

<https://spectacular-voyage.github.io/accord/ontology/releases/v0.1.0/ttl>
  dcat:downloadURL <https://spectacular-voyage.github.io/accord/ontology/releases/v0.1.0/ttl/accord-ontology.ttl> .

accord:Manifest a owl:Class ;
  rdfs:label "Manifest" ;
  rdfs:comment "A machine-readable container for one or more conformance cases. Manifests may carry human-readable titles and descriptions using Dublin Core terms." .

accord:TransitionCase a owl:Class ;
  rdfs:label "Transition case" ;
  rdfs:comment "A conformance case that compares an expected transition from one named state or fixture reference to another. Transition cases may carry human-readable titles and descriptions using Dublin Core terms." .

accord:FileExpectation a owl:Class ;
  rdfs:label "File expectation" ;
  rdfs:comment "An expectation about a file path, its expected change, and the comparison mode used to validate it." .

accord:RdfExpectation a owl:Class ;
  rdfs:label "RDF expectation" ;
  rdfs:comment "An expectation about RDF graph or dataset validation for a specific targeted file expectation, including ignored predicates and explicit graph assertions." .

accord:JsonExpectation a owl:Class ;
  rdfs:label "JSON expectation" ;
  rdfs:comment "An expectation about JSON document validation for a specific targeted file expectation, including explicit JSON path assertions." .

accord:SparqlAskAssertion a owl:Class ;
  rdfs:label "SPARQL ASK assertion" ;
  rdfs:comment "A SPARQL ASK query paired with the boolean value that must result during validation." .

accord:JsonAssertion a owl:Class ;
  rdfs:label "JSON assertion" ;
  rdfs:comment "A JSON path assertion paired with the expected existence, absence, scalar value, or match count." .

accord:StateLocator a owl:Class ;
  rdfs:label "State locator" ;
  rdfs:comment "A typed locator for a transition state, such as a git ref, directory snapshot, archive, or generated workspace." .

accord:ReplayProfile a owl:Class ;
  rdfs:label "Replay profile" ;
  rdfs:comment "Optional replay metadata that describes how a runner can reproduce a transition without making accord check execute it." .

accord:CommandInvocation a owl:Class ;
  rdfs:label "Command invocation" ;
  rdfs:comment "Command provenance for a replayable transition, including executable, ordered arguments, working directory, environment overrides, prompt policy, expected exit code, and log expectations." .

accord:EnvironmentOverride a owl:Class ;
  rdfs:label "Environment override" ;
  rdfs:comment "A named environment variable value that materially affects a replay command." .

accord:InputMaterialization a owl:Class ;
  rdfs:label "Input materialization" ;
  rdfs:comment "A file or directory source that should be materialized into a replay workspace before command execution." .

accord:FileOperation a owl:Class ;
  rdfs:label "File operation" ;
  rdfs:comment "A declared replay step for command-incomplete or manual transitions that creates, replaces, copies, or removes a path." .

accord:SourceProvenance a owl:Class ;
  rdfs:label "Source provenance" ;
  rdfs:comment "The origin of bytes used for replay input materialization or manual file operations." .

accord:ScenarioIndex a owl:Class ;
  rdfs:label "Scenario index" ;
  rdfs:comment "A fixture-owned topology document that orders transition manifests into a reusable conformance scenario without duplicating per-operation assertions." .

accord:ScenarioStep a owl:Class ;
  rdfs:label "Scenario step" ;
  rdfs:comment "One ordered step in a scenario index, normally pointing at a transition manifest and optionally binding scenario state lanes to state locators." .

accord:StateLane a owl:Class ;
  rdfs:label "State lane" ;
  rdfs:comment "A named state lane that spans scenario steps, such as an application source lane or a publication lane." .

accord:LaneStateBinding a owl:Class ;
  rdfs:label "Lane state binding" ;
  rdfs:comment "A per-step binding from a declared state lane to the state locators used before and after that step." .

accord:FileChangeType a owl:Class ;
  rdfs:label "File change type" ;
  rdfs:comment "A controlled set of expected file-state transition categories." .

accord:CompareMode a owl:Class ;
  rdfs:label "Compare mode" ;
  rdfs:comment "A controlled set of comparison strategies for expected outputs." .

accord:JsonAssertionKind a owl:Class ;
  rdfs:label "JSON assertion kind" ;
  rdfs:comment "A controlled set of JSON assertion operations supported by accord check." .

accord:StateLocatorKind a owl:Class ;
  rdfs:label "State locator kind" ;
  rdfs:comment "A controlled set of state locator categories." .

accord:FileOperationKind a owl:Class ;
  rdfs:label "File operation kind" ;
  rdfs:comment "A controlled set of replay file operation categories." .

accord:SourceKind a owl:Class ;
  rdfs:label "Source kind" ;
  rdfs:comment "A controlled set of source provenance categories." .

accord:PromptPolicy a owl:Class ;
  rdfs:label "Prompt policy" ;
  rdfs:comment "A controlled set of command prompt and confirmation policies for replay runners." .

accord:hasCase a owl:ObjectProperty ;
  rdfs:label "has case" ;
  rdfs:domain accord:Manifest ;
  rdfs:range accord:TransitionCase ;
  rdfs:comment "Links a manifest to one of its conformance cases." .

accord:hasFileExpectation a owl:ObjectProperty ;
  rdfs:label "has file expectation" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range accord:FileExpectation ;
  rdfs:comment "Links a transition case to an expected file-level outcome." .

accord:hasRdfExpectation a owl:ObjectProperty ;
  rdfs:label "has RDF expectation" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range accord:RdfExpectation ;
  rdfs:comment "Links a transition case to RDF-specific validation expectations." .

accord:hasJsonExpectation a owl:ObjectProperty ;
  rdfs:label "has JSON expectation" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range accord:JsonExpectation ;
  rdfs:comment "Links a transition case to JSON-specific validation expectations." .

accord:targetsFileExpectation a owl:ObjectProperty ;
  rdfs:label "targets file expectation" ;
  rdfs:range accord:FileExpectation ;
  rdfs:comment "Binds an artifact-level expectation to the file expectation whose content it validates." .

accord:hasAskAssertion a owl:ObjectProperty ;
  rdfs:label "has ASK assertion" ;
  rdfs:domain accord:RdfExpectation ;
  rdfs:range accord:SparqlAskAssertion ;
  rdfs:comment "Associates an RDF expectation with a SPARQL ASK assertion that must evaluate to the expected boolean." .

accord:hasJsonAssertion a owl:ObjectProperty ;
  rdfs:label "has JSON assertion" ;
  rdfs:domain accord:JsonExpectation ;
  rdfs:range accord:JsonAssertion ;
  rdfs:comment "Associates a JSON expectation with a JSON path assertion that must satisfy its declared assertion kind." .

accord:fromState a owl:ObjectProperty ;
  rdfs:label "from state" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range accord:StateLocator ;
  rdfs:comment "Links a transition case to a generalized starting state locator. Current fromRef values remain git-oriented convenience metadata rather than OWL subproperties because they point to literals, not StateLocator nodes." .

accord:toState a owl:ObjectProperty ;
  rdfs:label "to state" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range accord:StateLocator ;
  rdfs:comment "Links a transition case to a generalized expected state locator. Current toRef values remain git-oriented convenience metadata rather than OWL subproperties because they point to literals, not StateLocator nodes." .

accord:hasReplayProfile a owl:ObjectProperty ;
  rdfs:label "has replay profile" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range accord:ReplayProfile ;
  rdfs:comment "Links a transition case to optional metadata for replaying or regenerating the transition." .

accord:hasCommandInvocation a owl:ObjectProperty ;
  rdfs:label "has command invocation" ;
  rdfs:domain accord:ReplayProfile ;
  rdfs:range accord:CommandInvocation ;
  rdfs:comment "Associates a replay profile with the command invocation that can reproduce a command-backed transition." .

accord:hasEnvironmentOverride a owl:ObjectProperty ;
  rdfs:label "has environment override" ;
  rdfs:domain accord:CommandInvocation ;
  rdfs:range accord:EnvironmentOverride ;
  rdfs:comment "Associates a command invocation with an environment variable override that materially affects replay." .

accord:hasInputMaterialization a owl:ObjectProperty ;
  rdfs:label "has input materialization" ;
  rdfs:domain accord:ReplayProfile ;
  rdfs:range accord:InputMaterialization ;
  rdfs:comment "Associates a replay profile with source material that should be placed in a workspace before command execution." .

accord:hasFileOperation a owl:ObjectProperty ;
  rdfs:label "has file operation" ;
  rdfs:domain accord:ReplayProfile ;
  rdfs:range accord:FileOperation ;
  rdfs:comment "Associates a replay profile with a declared file operation for command-incomplete or manual transitions." .

accord:hasSourceProvenance a owl:ObjectProperty ;
  rdfs:label "has source provenance" ;
  rdfs:range accord:SourceProvenance ;
  rdfs:comment "Associates input materialization or file operations with the origin of the bytes used for replay." .

accord:hasStep a rdf:Property ;
  rdfs:label "has step" ;
  rdfs:domain accord:ScenarioIndex ;
  rdfs:comment "Associates a scenario index with its ordered steps. JSON-LD authors should represent this with an @list container so scenario step order is preserved." .

accord:hasStateLane a owl:ObjectProperty ;
  rdfs:label "has state lane" ;
  rdfs:domain accord:ScenarioIndex ;
  rdfs:range accord:StateLane ;
  rdfs:comment "Declares a named state lane available to the scenario's steps." .

accord:hasLaneBinding a owl:ObjectProperty ;
  rdfs:label "has lane binding" ;
  rdfs:domain accord:ScenarioStep ;
  rdfs:range accord:LaneStateBinding ;
  rdfs:comment "Associates a scenario step with a state lane binding for that step." .

accord:lane a owl:ObjectProperty ;
  rdfs:label "lane" ;
  rdfs:domain accord:LaneStateBinding ;
  rdfs:range accord:StateLane ;
  rdfs:comment "References the scenario state lane being bound by a lane state binding." .

accord:fromLaneState a owl:ObjectProperty ;
  rdfs:label "from lane state" ;
  rdfs:domain accord:LaneStateBinding ;
  rdfs:range accord:StateLocator ;
  rdfs:comment "Links a lane state binding to the lane's state before the scenario step." .

accord:toLaneState a owl:ObjectProperty ;
  rdfs:label "to lane state" ;
  rdfs:domain accord:LaneStateBinding ;
  rdfs:range accord:StateLocator ;
  rdfs:comment "Links a lane state binding to the lane's state after the scenario step." .

accord:locatorKind a owl:ObjectProperty ;
  rdfs:label "locator kind" ;
  rdfs:domain accord:StateLocator ;
  rdfs:range accord:StateLocatorKind ;
  rdfs:comment "Classifies the kind of state locator, such as a git ref, directory snapshot, archive, or generated workspace." .

accord:operationKind a owl:ObjectProperty ;
  rdfs:label "operation kind" ;
  rdfs:domain accord:FileOperation ;
  rdfs:range accord:FileOperationKind ;
  rdfs:comment "Classifies the replay file operation." .

accord:sourceKind a owl:ObjectProperty ;
  rdfs:label "source kind" ;
  rdfs:domain accord:SourceProvenance ;
  rdfs:range accord:SourceKind ;
  rdfs:comment "Classifies the origin of replay source bytes." .

accord:promptPolicy a owl:ObjectProperty ;
  rdfs:label "prompt policy" ;
  rdfs:domain accord:CommandInvocation ;
  rdfs:range accord:PromptPolicy ;
  rdfs:comment "Declares how a replay runner should handle command prompts or confirmations." .

accord:changeType a owl:ObjectProperty ;
  rdfs:label "change type" ;
  rdfs:domain accord:FileExpectation ;
  rdfs:range accord:FileChangeType ;
  rdfs:comment "Declares the expected change classification for a file." .

accord:compareMode a owl:ObjectProperty ;
  rdfs:label "compare mode" ;
  rdfs:domain accord:FileExpectation ;
  rdfs:range accord:CompareMode ;
  rdfs:comment "Declares the comparison strategy to use for validating an expectation." .

accord:ignorePredicate a owl:ObjectProperty ;
  rdfs:label "ignore predicate" ;
  rdfs:domain accord:RdfExpectation ;
  rdfs:comment "Identifies an RDF predicate IRI that should be ignored during strict equivalence checks, for example volatile timestamps." .

accord:jsonAssertionKind a owl:ObjectProperty ;
  rdfs:label "JSON assertion kind" ;
  rdfs:domain accord:JsonAssertion ;
  rdfs:range accord:JsonAssertionKind ;
  rdfs:comment "Declares whether a JSON assertion checks existence, absence, scalar equality, or match count." .

accord:operationId a owl:DatatypeProperty ;
  rdfs:label "operation id" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range xsd:string ;
  rdfs:comment "The operation identifier or command identifier whose behavior is being checked." .

accord:fixtureRepo a owl:DatatypeProperty ;
  rdfs:label "fixture repo" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range xsd:string ;
  rdfs:comment "Identifies the fixture repository whose named refs are used by the transition case." .

accord:defaultFixtureRepo a owl:DatatypeProperty ;
  rdfs:label "default fixture repo" ;
  rdfs:domain accord:ScenarioIndex ;
  rdfs:range xsd:string ;
  rdfs:comment "Identifies the default fixture repository for scenario steps that omit a more specific fixture identity." .

accord:fromRef a owl:DatatypeProperty ;
  rdfs:label "from ref" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range xsd:string ;
  rdfs:comment "The starting fixture, branch, or other named reference for a transition case." .

accord:toRef a owl:DatatypeProperty ;
  rdfs:label "to ref" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range xsd:string ;
  rdfs:comment "The expected resulting fixture, branch, or other named reference for a transition case." .

accord:ref a owl:DatatypeProperty ;
  rdfs:label "ref" ;
  rdfs:domain accord:StateLocator ;
  rdfs:range xsd:string ;
  rdfs:comment "A named state reference, such as a git branch, tag, or commit when locatorKind is accord:gitRefState." .

accord:uri a owl:DatatypeProperty ;
  rdfs:label "URI" ;
  rdfs:domain accord:StateLocator ;
  rdfs:range xsd:anyURI ;
  rdfs:comment "A URI locator for archive-backed, remote, or externally addressed state." .

accord:locatorPath a owl:DatatypeProperty ;
  rdfs:label "locator path" ;
  rdfs:domain accord:StateLocator ;
  rdfs:range xsd:string ;
  rdfs:comment "A directory, archive, or workspace path used by a state locator." .

accord:targetDesignatorPath a owl:DatatypeProperty ;
  rdfs:label "target designator path" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range xsd:string ;
  rdfs:comment "The designator path or analogous operation target within the checked domain model." .

accord:ignorePaths a owl:DatatypeProperty ;
  rdfs:label "ignore paths" ;
  rdfs:domain accord:TransitionCase ;
  rdfs:range xsd:string ;
  rdfs:comment "Repository-relative exact paths or /** subtree patterns that whole-tree transition completeness checks ignore unless an explicit file expectation names the same path." .

accord:manifestPath a owl:DatatypeProperty ;
  rdfs:label "manifest path" ;
  rdfs:domain accord:ScenarioStep ;
  rdfs:range xsd:string ;
  rdfs:comment "The repository-relative path to the transition manifest used by a scenario step." .

accord:caseId a owl:DatatypeProperty ;
  rdfs:label "case id" ;
  rdfs:domain accord:ScenarioStep ;
  rdfs:range xsd:string ;
  rdfs:comment "An optional transition case selector within the referenced manifest." .

accord:laneKey a owl:DatatypeProperty ;
  rdfs:label "lane key" ;
  rdfs:domain accord:StateLane ;
  rdfs:range xsd:string ;
  rdfs:comment "A scenario-local stable key for a state lane, such as source or publication." .

accord:branchPrefix a owl:DatatypeProperty ;
  rdfs:label "branch prefix" ;
  rdfs:range xsd:string ;
  rdfs:comment "A repository-local branch naming prefix used as scenario or lane-level default metadata." .

accord:assetRoot a owl:DatatypeProperty ;
  rdfs:label "asset root" ;
  rdfs:domain accord:ScenarioIndex ;
  rdfs:range xsd:string ;
  rdfs:comment "A repository-relative root containing scenario-level source assets or harness inputs." .

accord:path a owl:DatatypeProperty ;
  rdfs:label "path" ;
  rdfs:domain accord:FileExpectation ;
  rdfs:range xsd:string ;
  rdfs:comment "The file path whose expected state or change is being checked." .

accord:targetPath a owl:DatatypeProperty ;
  rdfs:label "target path" ;
  rdfs:range xsd:string ;
  rdfs:comment "The workspace-relative path targeted by an input materialization or replay file operation." .

accord:workspaceRoot a owl:DatatypeProperty ;
  rdfs:label "workspace root" ;
  rdfs:domain accord:ReplayProfile ;
  rdfs:range xsd:string ;
  rdfs:comment "The replay workspace root, expressed relative to the materialized fixture root when possible." .

accord:meshRoot a owl:DatatypeProperty ;
  rdfs:label "mesh root" ;
  rdfs:domain accord:ReplayProfile ;
  rdfs:range xsd:string ;
  rdfs:comment "The mesh root to use during replay, expressed relative to the workspace root when possible." .

accord:executable a owl:DatatypeProperty ;
  rdfs:label "executable" ;
  rdfs:domain accord:CommandInvocation ;
  rdfs:range xsd:string ;
  rdfs:comment "The executable name or path for a command invocation." .

accord:argv a rdf:Property ;
  rdfs:label "argv" ;
  rdfs:domain accord:CommandInvocation ;
  rdfs:comment "The ordered command arguments for a command invocation. JSON-LD authors should represent this with an @list container so argv order is preserved." .

accord:workingDirectory a owl:DatatypeProperty ;
  rdfs:label "working directory" ;
  rdfs:domain accord:CommandInvocation ;
  rdfs:range xsd:string ;
  rdfs:comment "The command working directory, expressed relative to the replay workspace root when possible." .

accord:expectedExitCode a owl:DatatypeProperty ;
  rdfs:label "expected exit code" ;
  rdfs:domain accord:CommandInvocation ;
  rdfs:range xsd:integer ;
  rdfs:comment "The command exit code expected by a replay runner." .

accord:expectsOperationalLogs a owl:DatatypeProperty ;
  rdfs:label "expects operational logs" ;
  rdfs:domain accord:CommandInvocation ;
  rdfs:range xsd:boolean ;
  rdfs:comment "Whether replay is expected to produce ordinary operational logs." .

accord:expectsAuditLogs a owl:DatatypeProperty ;
  rdfs:label "expects audit logs" ;
  rdfs:domain accord:CommandInvocation ;
  rdfs:range xsd:boolean ;
  rdfs:comment "Whether replay is expected to produce audit-grade logs." .

accord:name a owl:DatatypeProperty ;
  rdfs:label "name" ;
  rdfs:domain accord:EnvironmentOverride ;
  rdfs:range xsd:string ;
  rdfs:comment "The name of an environment variable override." .

accord:value a owl:DatatypeProperty ;
  rdfs:label "value" ;
  rdfs:domain accord:EnvironmentOverride ;
  rdfs:range xsd:string ;
  rdfs:comment "The value of an environment variable override." .

accord:sourcePath a owl:DatatypeProperty ;
  rdfs:label "source path" ;
  rdfs:domain accord:SourceProvenance ;
  rdfs:range xsd:string ;
  rdfs:comment "A local checked-in or fixture-relative source path for replay bytes." .

accord:sourceRef a owl:DatatypeProperty ;
  rdfs:label "source ref" ;
  rdfs:domain accord:SourceProvenance ;
  rdfs:range xsd:string ;
  rdfs:comment "A fixture or repository ref that qualifies a source path." .

accord:sourceUrl a owl:DatatypeProperty ;
  rdfs:label "source URL" ;
  rdfs:domain accord:SourceProvenance ;
  rdfs:range xsd:anyURI ;
  rdfs:comment "A remote URL where replay source bytes can be fetched." .

accord:inlineValue a owl:DatatypeProperty ;
  rdfs:label "inline value" ;
  rdfs:domain accord:SourceProvenance ;
  rdfs:range xsd:string ;
  rdfs:comment "Inline source bytes or text for small replay inputs." .

accord:contentDigest a owl:DatatypeProperty ;
  rdfs:label "content digest" ;
  rdfs:range xsd:string ;
  rdfs:comment "A content digest that pins replay source bytes or located state content, typically using an algorithm-prefixed value such as sha256:..." .

accord:mediaType a owl:DatatypeProperty ;
  rdfs:label "media type" ;
  rdfs:range xsd:string ;
  rdfs:comment "The media type of replay source bytes when handling depends on it." .

accord:derivationNote a owl:DatatypeProperty ;
  rdfs:label "derivation note" ;
  rdfs:domain accord:SourceProvenance ;
  rdfs:range xsd:string ;
  rdfs:comment "A short note explaining how manually authored or derived source bytes were produced." .

accord:derivedFrom a owl:DatatypeProperty ;
  rdfs:label "derived from" ;
  rdfs:domain accord:SourceProvenance ;
  rdfs:range xsd:anyURI ;
  rdfs:comment "A task, specification, source document, or other identifier that manually authored bytes were derived from." .

accord:nondeterministicSource a owl:DatatypeProperty ;
  rdfs:label "nondeterministic source" ;
  rdfs:domain accord:SourceProvenance ;
  rdfs:range xsd:boolean ;
  rdfs:comment "Marks URL-backed source provenance as intentionally nondeterministic when no content digest is available." .

accord:query a owl:DatatypeProperty ;
  rdfs:label "query" ;
  rdfs:domain accord:SparqlAskAssertion ;
  rdfs:range xsd:string ;
  rdfs:comment "The SPARQL ASK query text used for an explicit graph assertion." .

accord:expectedBoolean a owl:DatatypeProperty ;
  rdfs:label "expected boolean" ;
  rdfs:domain accord:SparqlAskAssertion ;
  rdfs:range xsd:boolean ;
  rdfs:comment "The expected boolean result for a SPARQL ASK assertion." .

accord:jsonPath a owl:DatatypeProperty ;
  rdfs:label "JSON path" ;
  rdfs:domain accord:JsonAssertion ;
  rdfs:range xsd:string ;
  rdfs:comment "The Accord JSON path expression used for an explicit JSON assertion." .

accord:expectedValue a owl:DatatypeProperty ;
  rdfs:label "expected value" ;
  rdfs:domain accord:JsonAssertion ;
  rdfs:comment "The expected scalar value for a JSON equality assertion." .

accord:expectedCount a owl:DatatypeProperty ;
  rdfs:label "expected count" ;
  rdfs:domain accord:JsonAssertion ;
  rdfs:range xsd:integer ;
  rdfs:comment "The expected number of matches for a JSON count assertion." .

accord:added a accord:FileChangeType ;
  rdfs:label "added" ;
  rdfs:comment "The file is expected to be added by the transition." .

accord:updated a accord:FileChangeType ;
  rdfs:label "updated" ;
  rdfs:comment "The file is expected to exist before and after the transition, with meaningful content changes." .

accord:unchanged a accord:FileChangeType ;
  rdfs:label "unchanged" ;
  rdfs:comment "The file is expected to exist before and after the transition with no meaningful content changes under the declared comparison mode." .

accord:removed a accord:FileChangeType ;
  rdfs:label "removed" ;
  rdfs:comment "The file is expected to be removed by the transition." .

accord:absent a accord:FileChangeType ;
  rdfs:label "absent" ;
  rdfs:comment "The file is expected not to exist in the checked state." .

accord:bytes a accord:CompareMode ;
  rdfs:label "bytes" ;
  rdfs:comment "Compare exact byte content." .

accord:text a accord:CompareMode ;
  rdfs:label "text" ;
  rdfs:comment "Compare text content after text-oriented normalization." .

accord:json a accord:CompareMode ;
  rdfs:label "json" ;
  rdfs:comment "Compare JSON content structurally rather than byte-for-byte." .

accord:rdfCanonical a accord:CompareMode ;
  rdfs:label "RDF canonical" ;
  rdfs:comment "Compare RDF content after dataset canonicalization and configured volatility exclusions." .

accord:exists a accord:JsonAssertionKind ;
  rdfs:label "exists" ;
  rdfs:comment "The JSON path must match at least one value." .

accord:notExists a accord:JsonAssertionKind ;
  rdfs:label "not exists" ;
  rdfs:comment "The JSON path must match no values." .

accord:equals a accord:JsonAssertionKind ;
  rdfs:label "equals" ;
  rdfs:comment "At least one JSON path match must equal the declared scalar expected value." .

accord:count a accord:JsonAssertionKind ;
  rdfs:label "count" ;
  rdfs:comment "The JSON path match count must equal the declared expected count." .

accord:gitRefState a accord:StateLocatorKind ;
  rdfs:label "git ref state" ;
  rdfs:comment "A state located by a git branch, tag, commit, or other ref." .

accord:directoryState a accord:StateLocatorKind ;
  rdfs:label "directory state" ;
  rdfs:comment "A state located by a directory snapshot." .

accord:archiveState a accord:StateLocatorKind ;
  rdfs:label "archive state" ;
  rdfs:comment "A state located by an archive." .

accord:generatedState a accord:StateLocatorKind ;
  rdfs:label "generated state" ;
  rdfs:comment "A state produced by a replay runner rather than named as a durable fixture ref." .

accord:createFile a accord:FileOperationKind ;
  rdfs:label "create file" ;
  rdfs:comment "A replay file operation that creates a file from source provenance." .

accord:replaceFile a accord:FileOperationKind ;
  rdfs:label "replace file" ;
  rdfs:comment "A replay file operation that replaces a file from source provenance." .

accord:copyPath a accord:FileOperationKind ;
  rdfs:label "copy path" ;
  rdfs:comment "A replay file operation that copies a file or directory from source provenance." .

accord:removePath a accord:FileOperationKind ;
  rdfs:label "remove path" ;
  rdfs:comment "A replay file operation that removes a file or directory." .

accord:inlineSource a accord:SourceKind ;
  rdfs:label "inline source" ;
  rdfs:comment "Source bytes or text carried inline in the manifest." .

accord:fixtureRefSource a accord:SourceKind ;
  rdfs:label "fixture ref source" ;
  rdfs:comment "Source bytes copied from a path at a fixture ref." .

accord:localPathSource a accord:SourceKind ;
  rdfs:label "local path source" ;
  rdfs:comment "Source bytes copied from a checked-in local path such as a replay asset." .

accord:remoteUrlSource a accord:SourceKind ;
  rdfs:label "remote URL source" ;
  rdfs:comment "Source bytes fetched from a remote URL and pinned by digest unless explicitly marked nondeterministic." .

accord:derivedSource a accord:SourceKind ;
  rdfs:label "derived source" ;
  rdfs:comment "Source bytes manually authored or derived from a task, spec, note, or other documented input rather than copied byte-for-byte." .

accord:nonInteractive a accord:PromptPolicy ;
  rdfs:label "non-interactive" ;
  rdfs:comment "Replay should not expect interactive prompts." .

accord:acceptPreview a accord:PromptPolicy ;
  rdfs:label "accept preview" ;
  rdfs:comment "Replay may accept a command preview or confirmation prompt." .

accord:expectedConfirmation a accord:PromptPolicy ;
  rdfs:label "expected confirmation" ;
  rdfs:comment "Replay expects a specific confirmation interaction." .
