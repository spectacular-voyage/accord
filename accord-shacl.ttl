@base <https://spectacular-voyage.github.io/accord/shacl/> .
@prefix accord: <https://spectacular-voyage.github.io/accord/ontology/> .
@prefix accord-sh: <https://spectacular-voyage.github.io/accord/shacl/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://spectacular-voyage.github.io/accord/shacl> a owl:Ontology ;
  dcterms:title "Accord SHACL Shapes" ;
  dcterms:description "SHACL shapes for validating Accord conformance manifests, replay metadata, and scenario indexes." ;
  dcterms:creator <https://djradon.github.io/ns/dave-richardson> ;
  dcterms:hasVersion <https://spectacular-voyage.github.io/accord/shacl/releases/v0.1.0> ;
  dcterms:modified "2026-05-23"^^xsd:date ;
  owl:versionIRI <https://raw.githubusercontent.com/spectacular-voyage/accord/refs/tags/v0.1.0/accord-shacl.ttl> ;
  owl:versionInfo "0.1.0" ;
  vann:preferredNamespacePrefix "accord-sh" ;
  vann:preferredNamespaceUri "https://spectacular-voyage.github.io/accord/shacl/" .

<https://spectacular-voyage.github.io/accord/shacl/releases/v0.1.0>
  a owl:Ontology, sflo:HistoricalState ;
  dcterms:isVersionOf <https://spectacular-voyage.github.io/accord/shacl> ;
  dcterms:issued "2026-05-23"^^xsd:date ;
  owl:versionInfo "0.1.0" ;
  schema:contentUrl <https://spectacular-voyage.github.io/accord/shacl/releases/v0.1.0/ttl/accord-shacl.ttl> ;
  sflo:hasManifestation <https://spectacular-voyage.github.io/accord/shacl/releases/v0.1.0/ttl> .

<https://spectacular-voyage.github.io/accord/shacl/releases/v0.1.0/ttl>
  dcat:downloadURL <https://spectacular-voyage.github.io/accord/shacl/releases/v0.1.0/ttl/accord-shacl.ttl> .

accord-sh:ManifestShape a sh:NodeShape ;
  sh:targetClass accord:Manifest ;
  sh:property [
    sh:path accord:hasCase ;
    sh:minCount 1 ;
    sh:node accord-sh:TransitionCaseShape ;
    sh:message "An Accord manifest must contain at least one transition case." ;
  ] ;
  sh:node accord-sh:CommonTextMetadataShape .

accord-sh:ScenarioIndexShape a sh:NodeShape ;
  sh:targetClass accord:ScenarioIndex ;
  sh:node accord-sh:CommonTextMetadataShape ;
  sh:property [
    sh:path accord:defaultFixtureRepo ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, defaultFixtureRepo must be a single string identifying the default fixture repository." ;
  ] ;
  sh:property [
    sh:path accord:branchPrefix ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, scenario branchPrefix must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:assetRoot ;
    sh:datatype xsd:string ;
    sh:message "assetRoot values must be repository-relative string paths." ;
  ] ;
  sh:property [
    sh:path accord:hasStateLane ;
    sh:class accord:StateLane ;
    sh:node accord-sh:StateLaneShape ;
    sh:message "Each state lane must satisfy the Accord state lane shape." ;
  ] ;
  sh:property [
    sh:path accord:hasStep ;
    sh:minCount 1 ;
    sh:message "A scenario index must contain an ordered hasStep list." ;
  ] ;
  sh:sparql [
    sh:message "A scenario index must not declare two distinct state lanes with the same laneKey." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:hasStateLane ?laneA, ?laneB .
        FILTER (?laneA != ?laneB)
        ?laneA accord:laneKey ?laneKey .
        ?laneB accord:laneKey ?laneKey .
      }
      LIMIT 1
    """ ;
  ] .

accord-sh:ScenarioStepShape a sh:NodeShape ;
  sh:targetClass accord:ScenarioStep ;
  sh:node accord-sh:CommonTextMetadataShape ;
  sh:property [
    sh:path accord:manifestPath ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A scenario step must declare exactly one manifestPath." ;
  ] ;
  sh:property [
    sh:path accord:caseId ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, caseId must be a single string selector." ;
  ] ;
  sh:property [
    sh:path accord:hasLaneBinding ;
    sh:class accord:LaneStateBinding ;
    sh:node accord-sh:LaneStateBindingShape ;
    sh:message "Each lane binding must satisfy the Accord lane state binding shape." ;
  ] ;
  sh:sparql [
    sh:message "manifestPath values must be repository-relative, must not contain parent traversal or backslashes, and must not be absolute." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:manifestPath ?path .
        FILTER (
          STRSTARTS(STR(?path), "/") ||
          CONTAINS(STR(?path), "..") ||
          CONTAINS(STR(?path), "\\\\")
        )
      }
      LIMIT 1
    """ ;
  ] .

accord-sh:StateLaneShape a sh:NodeShape ;
  sh:targetClass accord:StateLane ;
  sh:property [
    sh:path accord:laneKey ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A state lane must declare exactly one laneKey." ;
  ] ;
  sh:property [
    sh:path accord:branchPrefix ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, state lane branchPrefix must be a single string." ;
  ] .

accord-sh:LaneStateBindingShape a sh:NodeShape ;
  sh:targetClass accord:LaneStateBinding ;
  sh:property [
    sh:path accord:lane ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:class accord:StateLane ;
    sh:message "A lane state binding must reference exactly one declared state lane." ;
  ] ;
  sh:property [
    sh:path accord:fromLaneState ;
    sh:maxCount 1 ;
    sh:class accord:StateLocator ;
    sh:node accord-sh:StateLocatorShape ;
    sh:message "If present, fromLaneState must be a single Accord state locator." ;
  ] ;
  sh:property [
    sh:path accord:toLaneState ;
    sh:maxCount 1 ;
    sh:class accord:StateLocator ;
    sh:node accord-sh:StateLocatorShape ;
    sh:message "If present, toLaneState must be a single Accord state locator." ;
  ] ;
  sh:sparql [
    sh:message "A lane state binding must reference a state lane declared by the same scenario index." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
      SELECT $this WHERE {
        $this accord:lane ?lane .
        ?step accord:hasLaneBinding $this .
        {
          ?scenario accord:hasStep ?step .
        }
        UNION
        {
          ?scenario accord:hasStep/rdf:rest*/rdf:first ?step .
        }
        FILTER NOT EXISTS {
          ?scenario accord:hasStateLane ?lane .
        }
      }
      LIMIT 1
    """ ;
  ] .

accord-sh:TransitionCaseShape a sh:NodeShape ;
  sh:targetClass accord:TransitionCase ;
  sh:node accord-sh:CommonTextMetadataShape ;
  sh:property [
    sh:path accord:operationId ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A transition case must declare exactly one operationId." ;
  ] ;
  sh:property [
    sh:path accord:fixtureRepo ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, fixtureRepo must be a single string identifying the fixture repository." ;
  ] ;
  sh:property [
    sh:path accord:fromRef ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A transition case must declare exactly one fromRef." ;
  ] ;
  sh:property [
    sh:path accord:toRef ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A transition case must declare exactly one toRef." ;
  ] ;
  sh:property [
    sh:path accord:fromState ;
    sh:maxCount 1 ;
    sh:class accord:StateLocator ;
    sh:node accord-sh:StateLocatorShape ;
    sh:message "If present, fromState must be a single Accord state locator." ;
  ] ;
  sh:property [
    sh:path accord:toState ;
    sh:maxCount 1 ;
    sh:class accord:StateLocator ;
    sh:node accord-sh:StateLocatorShape ;
    sh:message "If present, toState must be a single Accord state locator." ;
  ] ;
  sh:property [
    sh:path accord:targetDesignatorPath ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, targetDesignatorPath must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:ignorePaths ;
    sh:datatype xsd:string ;
    sh:message "ignorePaths values must be repository-relative string paths or /** subtree patterns." ;
  ] ;
  sh:property [
    sh:path accord:hasReplayProfile ;
    sh:maxCount 1 ;
    sh:class accord:ReplayProfile ;
    sh:node accord-sh:ReplayProfileShape ;
    sh:message "If present, hasReplayProfile must be a single replay profile." ;
  ] ;
  sh:property [
    sh:path accord:hasFileExpectation ;
    sh:node accord-sh:FileExpectationShape ;
    sh:message "Each file expectation must satisfy the Accord file expectation shape." ;
  ] ;
  sh:property [
    sh:path accord:hasRdfExpectation ;
    sh:node accord-sh:RdfExpectationShape ;
    sh:message "If present, each RDF expectation must satisfy the Accord RDF expectation shape." ;
  ] ;
  sh:property [
    sh:path accord:hasJsonExpectation ;
    sh:node accord-sh:JsonExpectationShape ;
    sh:message "If present, each JSON expectation must satisfy the Accord JSON expectation shape." ;
  ] ;
  sh:sparql [
    sh:message "ignorePaths values must be repository-relative, must not contain parent traversal or backslashes, and may only use /** as a subtree suffix." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:ignorePaths ?path .
        FILTER (
          STRSTARTS(STR(?path), "/") ||
          CONTAINS(STR(?path), "..") ||
          CONTAINS(STR(?path), "\\\\") ||
          (CONTAINS(STR(?path), "*") && !STRENDS(STR(?path), "/**"))
        )
      }
      LIMIT 1
    """ ;
  ] .

accord-sh:FileExpectationShape a sh:NodeShape ;
  sh:targetClass accord:FileExpectation ;
  sh:property [
    sh:path accord:path ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A file expectation must declare exactly one path." ;
  ] ;
  sh:property [
    sh:path accord:changeType ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in ( accord:added accord:updated accord:unchanged accord:removed accord:absent ) ;
    sh:message "A file expectation must use one of the supported file change types." ;
  ] ;
  sh:property [
    sh:path accord:compareMode ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in ( accord:bytes accord:text accord:json accord:rdfCanonical ) ;
    sh:message "If present, compareMode must be one of the supported Accord comparison modes." ;
  ] ;
  sh:sparql [
    sh:message "File expectations with changeType accord:added, accord:updated, or accord:unchanged must declare compareMode." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:changeType ?changeType .
        FILTER (?changeType IN (accord:added, accord:updated, accord:unchanged))
        FILTER NOT EXISTS {
          $this accord:compareMode ?compareMode .
        }
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "File expectations with changeType accord:removed or accord:absent must not declare compareMode." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:changeType ?changeType ;
              accord:compareMode ?compareMode .
        FILTER (?changeType IN (accord:removed, accord:absent))
      }
    """ ;
  ] ;
  sh:or (
    [
      sh:not [
        sh:property [
          sh:path accord:compareMode ;
          sh:hasValue accord:rdfCanonical ;
        ]
      ]
    ]
    [
      sh:property [
        sh:path accord:compareMode ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue accord:rdfCanonical ;
      ] ;
      sh:property [
        sh:path [ sh:inversePath accord:targetsFileExpectation ] ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class accord:RdfExpectation ;
        sh:message "A file expectation with compareMode accord:rdfCanonical must be targeted by exactly one RDF expectation." ;
      ]
    ]
  ) .

accord-sh:RdfExpectationShape a sh:NodeShape ;
  sh:targetClass accord:RdfExpectation ;
  sh:property [
    sh:path accord:targetsFileExpectation ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:class accord:FileExpectation ;
    sh:node accord-sh:RdfTargetFileExpectationShape ;
    sh:message "An RDF expectation must target exactly one file expectation whose compareMode is accord:rdfCanonical." ;
  ] ;
  sh:property [
    sh:path accord:ignorePredicate ;
    sh:nodeKind sh:IRI ;
    sh:message "ignorePredicate values must be IRIs for RDF predicates." ;
  ] ;
  sh:property [
    sh:path accord:hasAskAssertion ;
    sh:node accord-sh:SparqlAskAssertionShape ;
    sh:message "Each ASK assertion must satisfy the Accord SPARQL ASK assertion shape." ;
  ] ;
  sh:sparql [
    sh:message "An RDF expectation must target a file expectation in the same transition case that contains the RDF expectation." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:targetsFileExpectation ?targetFileExpectation .
        ?case accord:hasRdfExpectation $this .
        FILTER NOT EXISTS {
          ?case accord:hasFileExpectation ?targetFileExpectation .
        }
      }
    """ ;
  ] .

accord-sh:RdfTargetFileExpectationShape a sh:NodeShape ;
  sh:property [
    sh:path accord:compareMode ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:hasValue accord:rdfCanonical ;
    sh:message "A file expectation targeted by an RDF expectation must use compareMode accord:rdfCanonical." ;
  ] .

accord-sh:SparqlAskAssertionShape a sh:NodeShape ;
  sh:targetClass accord:SparqlAskAssertion ;
  sh:property [
    sh:path accord:query ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A SPARQL ASK assertion must declare exactly one query." ;
  ] ;
  sh:property [
    sh:path accord:expectedBoolean ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "A SPARQL ASK assertion must declare exactly one expected boolean result." ;
  ] .

accord-sh:JsonExpectationShape a sh:NodeShape ;
  sh:targetClass accord:JsonExpectation ;
  sh:property [
    sh:path accord:targetsFileExpectation ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:class accord:FileExpectation ;
    sh:node accord-sh:JsonTargetFileExpectationShape ;
    sh:message "A JSON expectation must target exactly one file expectation whose toRef content exists." ;
  ] ;
  sh:property [
    sh:path accord:hasJsonAssertion ;
    sh:minCount 1 ;
    sh:node accord-sh:JsonAssertionShape ;
    sh:message "A JSON expectation must contain at least one well-formed JSON assertion." ;
  ] ;
  sh:sparql [
    sh:message "A JSON expectation must target a file expectation in the same transition case that contains the JSON expectation." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:targetsFileExpectation ?targetFileExpectation .
        ?case accord:hasJsonExpectation $this .
        FILTER NOT EXISTS {
          ?case accord:hasFileExpectation ?targetFileExpectation .
        }
      }
    """ ;
  ] .

accord-sh:JsonTargetFileExpectationShape a sh:NodeShape ;
  sh:property [
    sh:path accord:changeType ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( accord:added accord:updated accord:unchanged ) ;
    sh:message "A file expectation targeted by a JSON expectation must have toRef content: accord:added, accord:updated, or accord:unchanged." ;
  ] .

accord-sh:JsonAssertionShape a sh:NodeShape ;
  sh:targetClass accord:JsonAssertion ;
  sh:property [
    sh:path accord:jsonPath ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A JSON assertion must declare exactly one JSON path string." ;
  ] ;
  sh:property [
    sh:path accord:jsonAssertionKind ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in ( accord:exists accord:notExists accord:equals accord:count ) ;
    sh:message "A JSON assertion must use one supported assertion kind." ;
  ] ;
  sh:property [
    sh:path accord:expectedValue ;
    sh:maxCount 1 ;
    sh:or (
      [ sh:datatype xsd:string ]
      [ sh:datatype xsd:boolean ]
      [ sh:datatype xsd:integer ]
      [ sh:datatype xsd:decimal ]
      [ sh:datatype xsd:double ]
    ) ;
    sh:message "expectedValue, when present, must be a single scalar string, boolean, or number." ;
  ] ;
  sh:property [
    sh:path accord:expectedCount ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:minInclusive 0 ;
    sh:message "expectedCount, when present, must be a single non-negative integer." ;
  ] ;
  sh:sparql [
    sh:message "JSON equals assertions must declare expectedValue." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:jsonAssertionKind accord:equals .
        FILTER NOT EXISTS {
          $this accord:expectedValue ?expectedValue .
        }
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "Only JSON equals assertions may declare expectedValue." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:expectedValue ?expectedValue .
        FILTER NOT EXISTS {
          $this accord:jsonAssertionKind accord:equals .
        }
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "JSON count assertions must declare expectedCount." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:jsonAssertionKind accord:count .
        FILTER NOT EXISTS {
          $this accord:expectedCount ?expectedCount .
        }
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "Only JSON count assertions may declare expectedCount." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:expectedCount ?expectedCount .
        FILTER NOT EXISTS {
          $this accord:jsonAssertionKind accord:count .
        }
      }
    """ ;
  ] .

accord-sh:StateLocatorShape a sh:NodeShape ;
  sh:targetClass accord:StateLocator ;
  sh:property [
    sh:path accord:locatorKind ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in ( accord:gitRefState accord:directoryState accord:archiveState accord:generatedState ) ;
    sh:message "A state locator must use one supported locatorKind." ;
  ] ;
  sh:property [
    sh:path accord:ref ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, ref must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:locatorPath ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, locatorPath must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:uri ;
    sh:maxCount 1 ;
    sh:datatype xsd:anyURI ;
    sh:message "If present, uri must be a single URI." ;
  ] ;
  sh:property [
    sh:path accord:contentDigest ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, contentDigest must be a single string." ;
  ] .

accord-sh:ReplayProfileShape a sh:NodeShape ;
  sh:targetClass accord:ReplayProfile ;
  sh:property [
    sh:path accord:workspaceRoot ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, workspaceRoot must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:meshRoot ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, meshRoot must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:hasCommandInvocation ;
    sh:maxCount 1 ;
    sh:class accord:CommandInvocation ;
    sh:node accord-sh:CommandInvocationShape ;
    sh:message "If present, hasCommandInvocation must be a single command invocation." ;
  ] ;
  sh:property [
    sh:path accord:hasInputMaterialization ;
    sh:class accord:InputMaterialization ;
    sh:node accord-sh:InputMaterializationShape ;
    sh:message "Each input materialization must satisfy the Accord input materialization shape." ;
  ] ;
  sh:property [
    sh:path accord:hasFileOperation ;
    sh:class accord:FileOperation ;
    sh:node accord-sh:FileOperationShape ;
    sh:message "Each file operation must satisfy the Accord file operation shape." ;
  ] .

accord-sh:CommandInvocationShape a sh:NodeShape ;
  sh:targetClass accord:CommandInvocation ;
  sh:property [
    sh:path accord:executable ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A command invocation must declare exactly one executable." ;
  ] ;
  sh:property [
    sh:path accord:workingDirectory ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, workingDirectory must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:promptPolicy ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in ( accord:nonInteractive accord:acceptPreview accord:expectedConfirmation ) ;
    sh:message "If present, promptPolicy must use one supported Accord prompt policy." ;
  ] ;
  sh:property [
    sh:path accord:expectedExitCode ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:message "If present, expectedExitCode must be a single integer." ;
  ] ;
  sh:property [
    sh:path accord:expectsOperationalLogs ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "If present, expectsOperationalLogs must be a single boolean." ;
  ] ;
  sh:property [
    sh:path accord:expectsAuditLogs ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "If present, expectsAuditLogs must be a single boolean." ;
  ] ;
  sh:property [
    sh:path accord:hasEnvironmentOverride ;
    sh:class accord:EnvironmentOverride ;
    sh:node accord-sh:EnvironmentOverrideShape ;
    sh:message "Each environment override must satisfy the Accord environment override shape." ;
  ] .

accord-sh:EnvironmentOverrideShape a sh:NodeShape ;
  sh:targetClass accord:EnvironmentOverride ;
  sh:property [
    sh:path accord:name ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "An environment override must declare exactly one name." ;
  ] ;
  sh:property [
    sh:path accord:value ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "An environment override must declare exactly one value." ;
  ] .

accord-sh:InputMaterializationShape a sh:NodeShape ;
  sh:targetClass accord:InputMaterialization ;
  sh:property [
    sh:path accord:targetPath ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "An input materialization must declare exactly one targetPath." ;
  ] ;
  sh:property [
    sh:path accord:hasSourceProvenance ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class accord:SourceProvenance ;
    sh:node accord-sh:SourceProvenanceShape ;
    sh:message "An input materialization must declare exactly one source provenance node." ;
  ] .

accord-sh:FileOperationShape a sh:NodeShape ;
  sh:targetClass accord:FileOperation ;
  sh:property [
    sh:path accord:operationKind ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in ( accord:createFile accord:replaceFile accord:copyPath accord:removePath ) ;
    sh:message "A file operation must use one supported operationKind." ;
  ] ;
  sh:property [
    sh:path accord:targetPath ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A file operation must declare exactly one targetPath." ;
  ] ;
  sh:property [
    sh:path accord:hasSourceProvenance ;
    sh:maxCount 1 ;
    sh:class accord:SourceProvenance ;
    sh:node accord-sh:SourceProvenanceShape ;
    sh:message "If present, file operation source provenance must satisfy the Accord source provenance shape." ;
  ] ;
  sh:sparql [
    sh:message "createFile, replaceFile, and copyPath file operations must declare source provenance." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:operationKind ?operationKind .
        FILTER (?operationKind IN (accord:createFile, accord:replaceFile, accord:copyPath))
        FILTER NOT EXISTS {
          $this accord:hasSourceProvenance ?sourceProvenance .
        }
      }
    """ ;
  ] .

accord-sh:SourceProvenanceShape a sh:NodeShape ;
  sh:targetClass accord:SourceProvenance ;
  sh:property [
    sh:path accord:sourceKind ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in ( accord:inlineSource accord:fixtureRefSource accord:localPathSource accord:remoteUrlSource accord:derivedSource ) ;
    sh:message "Source provenance must use one supported sourceKind." ;
  ] ;
  sh:property [
    sh:path accord:sourcePath ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, sourcePath must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:sourceRef ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, sourceRef must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:sourceUrl ;
    sh:maxCount 1 ;
    sh:datatype xsd:anyURI ;
    sh:message "If present, sourceUrl must be a single URI." ;
  ] ;
  sh:property [
    sh:path accord:inlineValue ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, inlineValue must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:contentDigest ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, contentDigest must be a single string." ;
  ] ;
  sh:property [
    sh:path accord:nondeterministicSource ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "If present, nondeterministicSource must be a single boolean." ;
  ] ;
  sh:sparql [
    sh:message "URL-backed source provenance must include contentDigest unless nondeterministicSource is true." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:sourceKind accord:remoteUrlSource .
        FILTER NOT EXISTS {
          $this accord:contentDigest ?contentDigest .
        }
        FILTER NOT EXISTS {
          $this accord:nondeterministicSource true .
        }
      }
    """ ;
  ] .

accord-sh:CommonTextMetadataShape a sh:NodeShape ;
  sh:and (
    accord-sh:TitleChoiceShape
    accord-sh:DescriptionChoiceShape
  ) .

accord-sh:TransitionCaseShape
  sh:sparql [
    sh:message "A transition case must not contain two distinct file expectations for the same path." ;
    sh:select """
      PREFIX accord: <https://spectacular-voyage.github.io/accord/ontology/>
      SELECT $this WHERE {
        $this accord:hasFileExpectation ?fileExpectationA, ?fileExpectationB .
        FILTER (?fileExpectationA != ?fileExpectationB)
        ?fileExpectationA accord:path ?path .
        ?fileExpectationB accord:path ?path .
      }
      LIMIT 1
    """ ;
  ] .

accord-sh:TitleChoiceShape a sh:NodeShape ;
  sh:or (
    accord-sh:TitlePlainStringShape
    accord-sh:TitleLangStringShape
  ) .

accord-sh:TitlePlainStringShape a sh:NodeShape ;
  sh:property [
    sh:path dcterms:title ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, titles may be expressed as a single plain string." ;
  ] .

accord-sh:TitleLangStringShape a sh:NodeShape ;
  sh:property [
    sh:path dcterms:title ;
    sh:datatype rdf:langString ;
    sh:uniqueLang true ;
    sh:message "If present, language-tagged titles must have at most one value per language." ;
  ] .

accord-sh:DescriptionChoiceShape a sh:NodeShape ;
  sh:or (
    accord-sh:DescriptionPlainStringShape
    accord-sh:DescriptionLangStringShape
  ) .

accord-sh:DescriptionPlainStringShape a sh:NodeShape ;
  sh:property [
    sh:path dcterms:description ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "If present, descriptions may be expressed as a single plain string." ;
  ] .

accord-sh:DescriptionLangStringShape a sh:NodeShape ;
  sh:property [
    sh:path dcterms:description ;
    sh:datatype rdf:langString ;
    sh:uniqueLang true ;
    sh:message "If present, language-tagged descriptions must have at most one value per language." ;
  ] .
